---
import "../styles/global.css";
import Socials from "../components/socials.astro";
---

<html lang="en" class="overflow-y-scroll scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Shreehari R Acharya</title>
		<meta
			name="description"
			content="Looking for a developer named Shreehari? You found the right one!"
		/>
		<meta
			name="keywords"
			content="Shreehari, Acharya, shreehari R Acharya, dev"
		/>
		<meta name="author" content="Shreehari R Acharya" />
		<link rel="canonical" href="https://shreehari.dev/" />
		<meta property="og:title" content="Shreehari R Acharya" />
		<meta
			property="og:description"
			content="Shreehari R Acharya, forging products with code"
		/>
		<meta property="og:url" content="https://shreehari.dev/" />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/og-image.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Shreehari R Acharya" />
		<meta
			name="twitter:description"
			content="Shreehari R Acharya, forging products with code"
		/>
		<meta name="twitter:image" content="/og-image.png" />
		<meta name="twitter:site" content="@06_Shreehari" />
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Shreehari R Acharya",
				"url": "https://shreehari.dev/",
				"sameAs": [
					"https://github.com/Shreehari-Acharya",
					"https://www.linkedin.com/in/shreehari-acharya/",
					"https://x.com/06_Shreehari",
					"https://shreehari-06.hashnode.dev/"
				],
				"jobTitle": "CS Engineering Student"
			}
		</script>

		<script
			src="https://cdn.jsdelivr.net/npm/iconify-icon@2.3.0/dist/iconify-icon.min.js"
		></script>
	</head>
	<body class="bg-slate-950 font-JetBrainsMono text-slate-200/90 flex justify-center items-center min-h-screen">
		<main class="flex flex-col items-center justify-center px-4 text-center">
			<h1 class="mb-4 text-6xl md:text-7xl font-bold">404</h1>
			<p class="mb-8 text-lg">Oops! The page you're looking for doesn't exist.</p>
			<a href="/" class="text-lg text-blue-500 hover:underline pb-4">Go Back Home</a>
			<Socials />
		</main>
			
	</body>
</html>
