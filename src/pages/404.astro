---
import "../styles/global.css";
import Socials from "../components/socials.astro";
---

<html lang="en" class="overflow-y-scroll scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Shreehari R Acharya</title>
		<meta
			name="description"
			content="Looking for a developer named Shreehari? You found the right one!"
		/>
		<meta
			name="keywords"
			content="Shreehari, Acharya, shreehari R Acharya, dev"
		/>
		<meta name="author" content="Shreehari R Acharya" />
		<link rel="canonical" href="https://shreehari.dev/" />
		<meta property="og:title" content="Shreehari R Acharya" />
		<meta
			property="og:description"
			content="Shreehari R Acharya, forging products with code"
		/>
		<meta property="og:url" content="https://shreehari.dev/" />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/og-image.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Shreehari R Acharya" />
		<meta
			name="twitter:description"
			content="Shreehari R Acharya, forging products with code"
		/>
		<meta name="twitter:image" content="/og-image.png" />
		<meta name="twitter:site" content="@06_Shreehari" />
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Shreehari R Acharya",
				"url": "https://shreehari.dev/",
				"sameAs": [
					"https://github.com/Shreehari-Acharya",
					"https://www.linkedin.com/in/shreehari-acharya/",
					"https://x.com/06_Shreehari",
					"https://shreehari-06.hashnode.dev/"
				],
				"jobTitle": "CS Engineering Student"
			}
		</script>

	</head>
	<body class="overflow-x-hidden antialiased">
		<main class="page-shell flex min-h-screen items-center justify-center py-10">
			<div class="flex w-full max-w-2xl flex-col items-center gap-8 px-6 py-10 text-center md:px-10 md:py-12">
				<h1 class="text-6xl font-semibold leading-none tracking-[-0.08em] text-slate-50 md:text-8xl">
					404
				</h1>
				<p class="max-w-md text-lg text-slate-300/82">
					Oops! The page you're looking for doesn't exist.
				</p>
				<a href="/" class="pill-link">Go Back Home</a>
				<Socials />
			</div>
		</main>
	</body>
</html>
