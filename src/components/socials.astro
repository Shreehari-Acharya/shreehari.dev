---
const size = "20"
import links from "../contents/links.json";
---

<div class="flex gap-6 items-center">
    <a href={links.gitHub} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="group">
        <iconify-icon width={size} height={size} icon="ri:github-fill" class="text-slate-400 group-hover:text-white group-hover:scale-110 transition-all duration-200"></iconify-icon>
    </a>
    <a href={links.linkedIn} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="group">
        <iconify-icon width={size} height={size} icon="ri:linkedin-fill" class="text-slate-400 group-hover:text-white group-hover:scale-110 transition-all duration-200"></iconify-icon>
    </a>
    <a href={links.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="group">
        <iconify-icon width={size} height={size} icon="ri:twitter-x-line" class="text-slate-400 group-hover:text-white group-hover:scale-110 transition-all duration-200"></iconify-icon>
    </a>
    <a href={links.email} target="_blank" rel="noopener noreferrer" aria-label="Email" class="group">
        <iconify-icon width={size} height={size} icon="material-symbols:mail-outline" class="text-slate-400 group-hover:text-white group-hover:scale-110 transition-all duration-200"></iconify-icon>
    </a>
</div>