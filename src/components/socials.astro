---
import links from "../contents/links.json";
---

<div class="flex flex-wrap items-center gap-5">
	<a
		href={links.gitHub}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="GitHub"
		class="social-link"
	>
		<svg
			viewBox="0 0 24 24"
			aria-hidden="true"
			class="h-[1.1rem] w-[1.1rem] fill-current"
		>
			<path
				d="M12 1.75A10.25 10.25 0 0 0 8.76 21.74c.52.1.71-.22.71-.5v-1.91c-2.9.63-3.51-1.23-3.51-1.23-.47-1.18-1.16-1.49-1.16-1.49-.94-.63.07-.62.07-.62 1.04.08 1.58 1.07 1.58 1.07.93 1.58 2.43 1.12 3.02.86.09-.68.36-1.13.65-1.39-2.31-.26-4.74-1.15-4.74-5.13 0-1.13.4-2.06 1.07-2.79-.11-.26-.47-1.34.1-2.79 0 0 .88-.28 2.89 1.07a9.96 9.96 0 0 1 5.25 0c2.01-1.35 2.89-1.07 2.89-1.07.57 1.45.21 2.53.1 2.79.66.73 1.07 1.66 1.07 2.79 0 4-2.44 4.87-4.76 5.12.38.33.71.97.71 1.96v2.9c0 .28.19.61.72.5A10.25 10.25 0 0 0 12 1.75Z"
			/>
		</svg>
	</a>
	<a
		href={links.linkedIn}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="LinkedIn"
		class="social-link"
	>
		<svg
			viewBox="0 0 24 24"
			aria-hidden="true"
			class="h-[1.1rem] w-[1.1rem] fill-current"
		>
			<path
				d="M5.37 3.5a1.87 1.87 0 1 1 0 3.74 1.87 1.87 0 0 1 0-3.74Zm-1.62 5.6h3.25V20.5H3.75V9.1ZM9.04 9.1h3.11v1.56h.04c.43-.82 1.5-1.68 3.08-1.68 3.29 0 3.9 2.17 3.9 4.99v6.53h-3.25v-5.79c0-1.38-.02-3.16-1.93-3.16-1.93 0-2.22 1.5-2.22 3.06v5.89H9.04V9.1Z"
			/>
		</svg>
	</a>
	<a
		href={links.twitter}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Twitter"
		class="social-link"
	>
		<svg
			viewBox="0 0 24 24"
			aria-hidden="true"
			class="h-[1rem] w-[1rem] fill-current"
		>
			<path
				d="M18.9 2.25H22l-6.77 7.74L23.2 21.75h-6.24l-4.89-6.98-6.1 6.98H2.86l7.25-8.3L.8 2.25H7.2l4.42 6.3 5.28-6.3Zm-1.1 17.54h1.73L6.26 4.1H4.4l13.4 15.69Z"
			/>
		</svg>
	</a>
	<a
		href={links.email}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Email"
		class="social-link"
	>
		<svg
			viewBox="0 0 24 24"
			aria-hidden="true"
			class="h-[1.1rem] w-[1.1rem] fill-none stroke-current"
			stroke-linecap="round"
			stroke-linejoin="round"
			stroke-width="1.8"
		>
			<path d="M4 6.75h16a1 1 0 0 1 1 1v8.5a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-8.5a1 1 0 0 1 1-1Z"></path>
			<path d="m4 8 8 5.5L20 8"></path>
		</svg>
	</a>
</div>
